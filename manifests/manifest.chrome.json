{
  "manifest_version": 3,
  "name": "Better Intra",
  "version": "1.0.8",
  "description": "UI and UX improvements for 42 Intra: logtime calendar, cluster map tools, custom profiles, shortcuts, friends widget, and more.",
  "permissions": ["storage", "activeTab", "notifications", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["hook.js"],
      "matches": ["https://*.intra.42.fr/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Better Intra"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "incognito": "not_allowed",
  "host_permissions": [
    "https://better-intra-worker.nicopasla.workers.dev/"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.intra.42.fr/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
