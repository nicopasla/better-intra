{
  "name": "better-intra",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "watch": "vite build --watch",
    "web-ext": "web-ext run --keep-profile-changes --source-dir dist --start-url https://profile-v3.intra.42.fr",
    "dev": "concurrently \"npm run watch\" \"npm run web-ext\""
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "web-ext": "^10.1.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "lit-html": "^3.3.3"
  }
  
}
