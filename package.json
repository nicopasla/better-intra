{
  "name": "better-intra",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "watch": "vite build --watch",
    "web-ext:firefox": "web-ext run --keep-profile-changes --source-dir dist --start-url https://profile-v3.intra.42.fr",
    "web-ext:chrome": "web-ext run -t chromium --source-dir dist --start-url https://profile-v3.intra.42.fr",
    "web-ext:brave": "web-ext run -t chromium --chromium-binary \"C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe\" --source-dir dist --start-url https://profile-v3.intra.42.fr",
    "dev:firefox": "concurrently \"npm run watch\" \"npm run web-ext:firefox\"",
    "dev:chrome": "concurrently \"npm run watch\" \"npm run web-ext:chrome\"",
    "dev:brave": "concurrently \"npm run watch\" \"npm run web-ext:brave\""
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.20",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "web-ext": "^10.1.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "lit-html": "^3.3.3"
  }
  
}
