{
  "manifest_version": 3,
  "name": "Better Intra",
  "version": "1.0.8",
  "description": "Collection of features inside a single extension that improve UI and UX of the 42 Intra v3.",
  "permissions": ["storage", "notifications", "alarms"],
  "web_accessible_resources": [
    {
      "resources": ["hook.js"],
      "matches": ["https://*.intra.42.fr/*"]
    }
  ],
  "incognito": "not_allowed",
  "host_permissions": ["https://better-intra-worker.nicopasla.workers.dev/"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://*.intra.42.fr/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "better-intra@nicopasla.42",
      "strict_min_version": "140.0",
      "update_url": "https://raw.githubusercontent.com/nicopasla/better-intra/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
